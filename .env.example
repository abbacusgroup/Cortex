# Cortex Configuration
# `cortex setup` generates this file automatically at ~/.cortex/.env
# You can also edit it directly — changes take effect on next service restart.

# Data directory (default: ~/.cortex)
# CORTEX_DATA_DIR=~/.cortex

# Server
# CORTEX_HOST=127.0.0.1
# CORTEX_PORT=1314

# LLM Provider (via litellm)
# CORTEX_LLM_PROVIDER=anthropic
# CORTEX_LLM_MODEL=claude-sonnet-4-20250514
# CORTEX_LLM_API_KEY=sk-...

# Embeddings (default: sentence-transformers/all-mpnet-base-v2)
# CORTEX_EMBEDDING_PROVIDER=sentence-transformers
# CORTEX_EMBEDDING_MODEL=all-mpnet-base-v2

# Logging
# CORTEX_LOG_LEVEL=INFO
# CORTEX_LOG_JSON=true

# Dashboard password (bcrypt hash will be generated on first setup)
# CORTEX_DASHBOARD_PASSWORD=

# Obsidian vault path for export
# CORTEX_VAULT_PATH=~/path/to/your/vault
